# Configuração do Banco de Dados PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL=false

# Segredo JWT para autenticação admin (gere com: openssl rand -hex 64)
JWT_SECRET=replace-with-a-strong-random-secret-of-at-least-64-chars

# Token obrigatório para o endpoint /api/setup (criação do primeiro admin)
SETUP_TOKEN=

# Ambiente
NODE_ENV=production
PORT=3000

# (Opcional) API Keys
RESEND_API_KEY=
GROQ_API_KEY=
